<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Synapse.Studio.ViewModels"
        xmlns:views="using:Synapse.Studio.Views"
        xmlns:contracts="using:Synapse.Studio.Contracts"
        x:Class="Synapse.Studio.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Synapse Studio"
        Width="1440" Height="900"
        MinWidth="1100" MinHeight="700"
        Background="#080C10"
        KeyDown="OnWindowKeyDown">

  <DockPanel>
    <Border DockPanel.Dock="Top" Background="#0A1018" BorderBrush="#1A2433" BorderThickness="0,0,0,1" Padding="16,10">
      <Grid ColumnDefinitions="Auto,*,Auto">
        <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
          <Border Width="28" Height="28" CornerRadius="14" Background="#122820" BorderBrush="#45E0B8" BorderThickness="1.5">
            <Ellipse Width="10" Height="10" Fill="#45E0B8" HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
          <StackPanel VerticalAlignment="Center" Spacing="0">
            <TextBlock Text="Synapse Studio" FontWeight="SemiBold" FontSize="15" Foreground="#EEF4FC" />
            <TextBlock Text="SYNAPSE OMNIA · Simulation 3D professionnelle" FontSize="10" Foreground="#6B8299" />
          </StackPanel>
        </StackPanel>
        <TextBlock Grid.Column="1" Text="{Binding ViewportHint}" Foreground="#5A7088" FontSize="11"
                   HorizontalAlignment="Center" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
        <Border Grid.Column="2" Background="#122820" CornerRadius="4" Padding="8,4" VerticalAlignment="Center">
          <TextBlock Text="v1.0" Foreground="#45E0B8" FontSize="11" FontWeight="SemiBold" FontFamily="Consolas" />
        </Border>
      </Grid>
    </Border>

    <Menu DockPanel.Dock="Top" Background="#0E141C">
      <MenuItem Header="_Fichier">
        <MenuItem Header="Nouveau projet" Command="{Binding NewProjectCommand}" />
        <MenuItem Header="Ouvrir…" Command="{Binding OpenProjectCommand}" />
        <MenuItem Header="Enregistrer" Command="{Binding SaveProjectCommand}" />
        <Separator />
        <MenuItem Header="Exporter Web Studio (WASM)…" Command="{Binding ExportWebStudioCommand}" />
        <Separator />
        <MenuItem Header="Quitter" Command="{Binding ExitCommand}" />
      </MenuItem>
      <MenuItem Header="_Simulation">
        <MenuItem Header="Lecture / Pause (Espace)" Command="{Binding TogglePlayCommand}" />
        <MenuItem Header="Créer un agent sentient" Command="{Binding SpawnAgentCommand}" />
        <Separator />
        <MenuItem Header="Mode inspecteur live" Command="{Binding ToggleInspectorModeCommand}"
                  ToggleType="CheckBox" IsChecked="{Binding IsInspectorModeEnabled}" />
      </MenuItem>
      <MenuItem Header="_Collaboration">
        <MenuItem Header="Activer VR OpenXR" Command="{Binding EnableVrCommand}" />
        <MenuItem Header="Arrêter VR" Command="{Binding DisableVrCommand}" />
        <Separator />
        <MenuItem Header="Héberger session WAN" Command="{Binding StartWanHostCommand}" />
        <MenuItem Header="Rejoindre session WAN" Command="{Binding JoinWanCommand}" />
        <MenuItem Header="Quitter WAN" Command="{Binding StopWanCommand}" />
      </MenuItem>
      <MenuItem Header="_Aide">
        <MenuItem Header="À propos" Command="{Binding AboutCommand}" />
        <MenuItem Header="Tarifs &amp; licence" Command="{Binding OpenPricingCommand}" />
        <MenuItem Header="Masquer l'accueil" Command="{Binding DismissWelcomeCommand}" />
      </MenuItem>
    </Menu>

    <Border DockPanel.Dock="Bottom" Background="#0E141C" BorderBrush="#1A2433" BorderThickness="0,1,0,0" Padding="14,7">
      <Grid ColumnDefinitions="Auto,*,*,*,*,*,Auto">
        <TextBlock Grid.Column="0" Foreground="#45E0B8" Text="Synapse" FontWeight="SemiBold" FontSize="11" Margin="0,0,16,0" VerticalAlignment="Center" />
        <TextBlock Grid.Column="1" Foreground="#7A92A8" Text="{Binding StatusFps}" FontSize="11" />
        <TextBlock Grid.Column="2" Foreground="#7A92A8" Text="{Binding StatusPhysics}" FontSize="11" />
        <TextBlock Grid.Column="3" Foreground="#7A92A8" Text="{Binding StatusSimulation}" FontSize="11" />
        <TextBlock Grid.Column="4" Foreground="#7A92A8" Text="{Binding StatusQuality}" FontSize="11" />
        <TextBlock Grid.Column="5" Foreground="#7A92A8" Text="{Binding CollaborationStatus}" FontSize="11" TextTrimming="CharacterEllipsis" />
        <TextBlock Grid.Column="6" Foreground="#45E0B8" Text="{Binding StatusLaw}" FontSize="11" HorizontalAlignment="Right" />
      </Grid>
    </Border>

    <Grid ColumnDefinitions="300,*,340">
      <!-- Left: tabbed tools -->
      <Border Grid.Column="0" Background="#12171F" BorderBrush="#1E2633" BorderThickness="0,0,1,0" Padding="8">
        <DockPanel>
          <Border DockPanel.Dock="Top" Background="#101820" CornerRadius="8" Padding="14" Margin="0,0,0,10"
                  BorderBrush="#1E3040" BorderThickness="1"
                  IsVisible="{Binding ShowWelcomeTips}">
            <StackPanel Spacing="8">
              <TextBlock Text="Bienvenue dans Synapse Studio v1" FontWeight="SemiBold" Foreground="#45E0B8" FontSize="14" />
              <TextBlock Text="Plateforme de simulation 3D — formes apprises, lois réécrivables, évolution et agents sentients dans un seul atelier."
                         Foreground="#B8C8D8" TextWrapping="Wrap" FontSize="12" LineHeight="18" />
              <TextBlock Text="① Scène · ② Lois · ③ Simulation (Espace) · ④ Assistant créatif"
                         Foreground="#6B8299" FontSize="11" />
              <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="Commencer" Command="{Binding DismissWelcomeCommand}" />
                <Button Content="Tarifs" Command="{Binding OpenPricingCommand}" />
              </StackPanel>
            </StackPanel>
          </Border>

          <TabControl>
            <TabItem Header="Scène">
              <ScrollViewer>
                <StackPanel Spacing="10" Margin="4">
                  <TextBlock Text="Entités" FontWeight="SemiBold" Foreground="#E8EEF7" />
                  <ListBox ItemsSource="{Binding Entities}" SelectedItem="{Binding SelectedEntity}"
                           Background="Transparent" MaxHeight="260">
                    <ListBox.ItemTemplate>
                      <DataTemplate DataType="contracts:SceneEntity">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                          <TextBlock Text="{Binding Type}" Foreground="#45E0B8" Width="72" FontSize="11" />
                          <TextBlock Text="{Binding Name}" Foreground="#E8EEF7" />
                        </StackPanel>
                      </DataTemplate>
                    </ListBox.ItemTemplate>
                  </ListBox>
                  <ComboBox ItemsSource="{Binding EntityTypes}" SelectedItem="{Binding NewEntityType}" />
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="Ajouter" Command="{Binding AddEntityCommand}" />
                    <Button Content="Supprimer" Command="{Binding DeleteEntityCommand}" />
                  </StackPanel>
                  <Button Content="▶ Lecture / Pause" Command="{Binding TogglePlayCommand}" HorizontalAlignment="Stretch" />
                  <Button Content="Créer un agent sentient" Command="{Binding SpawnAgentCommand}" HorizontalAlignment="Stretch" />
                </StackPanel>
              </ScrollViewer>
            </TabItem>

            <TabItem Header="Physique">
              <ScrollViewer>
                <StackPanel Spacing="10" Margin="4">
                  <TextBlock Text="Lois vivantes" FontWeight="SemiBold" Foreground="#E8EEF7" />
                  <TextBlock Text="Choisissez une loi, éditez l'expression, puis compilez sans arrêter la simulation."
                             Foreground="#8B9BB4" TextWrapping="Wrap" FontSize="11" />
                  <ComboBox ItemsSource="{Binding LawIds}" SelectedItem="{Binding SelectedLawId}" />
                  <TextBox Text="{Binding LawExpression}" AcceptsReturn="True" Height="90"
                           Watermark="Expression de loi…" TextWrapping="Wrap" />
                  <Button Content="Compiler &amp; hot-reload" Command="{Binding CompileLawCommand}" HorizontalAlignment="Stretch" />
                  <TextBlock Text="{Binding LawStatus}" Foreground="#8B9BB4" TextWrapping="Wrap" FontSize="11" />
                </StackPanel>
              </ScrollViewer>
            </TabItem>

            <TabItem Header="Création">
              <ScrollViewer>
                <StackPanel Spacing="10" Margin="4">
                  <TextBlock Text="Évolution NEAT-G" FontWeight="SemiBold" Foreground="#E8EEF7" />
                  <TextBlock Text="Fait muter des formes ; le meilleur génome apparaît comme volume dans la scène."
                             Foreground="#8B9BB4" TextWrapping="Wrap" FontSize="11" />
                  <TextBlock Text="{Binding EvolutionStatus}" Foreground="#C5D0E0" />
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="Évoluer" Command="{Binding StartEvolutionCommand}" />
                    <Button Content="Annuler" Command="{Binding CancelEvolutionCommand}" />
                  </StackPanel>

                  <Separator Margin="0,8" />

                  <TextBlock Text="Blueprint agent sentient" FontWeight="SemiBold" Foreground="#E8EEF7" />
                  <views:BlueprintGraphCanvas x:Name="BlueprintCanvas" Height="180" DocumentChanged="OnBlueprintDocumentChanged" />
                  <ListBox ItemsSource="{Binding BlueprintNodes}" Height="70" Background="#0E1218" />
                  <TextBlock Text="{Binding BlueprintStatus}" Foreground="#8B9BB4" TextWrapping="Wrap" FontSize="11" />
                  <CheckBox Content="Édition live (hot-reload)" IsChecked="{Binding BlueprintLiveEdit}" Foreground="#E8EEF7" />
                  <StackPanel Orientation="Horizontal" Spacing="6">
                    <Button Content="Nœud" Command="{Binding AddBlueprintNodeCommand}" />
                    <Button Content="LLM" Command="{Binding AddBlueprintLlmNodeCommand}" />
                    <Button Content="Compiler" Command="{Binding CompileBlueprintCommand}" />
                  </StackPanel>
                  <StackPanel Orientation="Horizontal" Spacing="6">
                    <Button Content="Nouveau" Command="{Binding NewBlueprintCommand}" />
                    <Button Content="Ouvrir" Command="{Binding OpenBlueprintCommand}" />
                    <Button Content="Enregistrer" Command="{Binding SaveBlueprintCommand}" />
                  </StackPanel>

                  <Separator Margin="0,8" />

                  <TextBlock Text="Sculpt (aperçu)" FontWeight="SemiBold" Foreground="#E8EEF7" />
                  <TextBlock Text="Rayon" Foreground="#8B9BB4" FontSize="11" />
                  <Slider Minimum="0.05" Maximum="3" Value="{Binding SculptRadius}" />
                  <TextBlock Text="Force" Foreground="#8B9BB4" FontSize="11" />
                  <Slider Minimum="0.01" Maximum="1" Value="{Binding SculptStrength}" />
                  <Button Content="Appliquer sur sélection" Command="{Binding ApplySculptStrokeCommand}" HorizontalAlignment="Stretch" />
                  <TextBlock Text="{Binding SculptStatus}" Foreground="#8B9BB4" FontSize="11" TextWrapping="Wrap" />
                </StackPanel>
              </ScrollViewer>
            </TabItem>

            <TabItem Header="Import">
              <ScrollViewer>
                <StackPanel Spacing="10" Margin="4">
                  <TextBlock Text="Megascans" FontWeight="SemiBold" Foreground="#E8EEF7" />
                  <TextBox Text="{Binding MegascansPath}" Watermark="Dossier d'asset…" />
                  <Button Content="Importer" Command="{Binding ImportMegascansCommand}" HorizontalAlignment="Stretch" />
                  <TextBlock Text="{Binding MegascansStatus}" Foreground="#8B9BB4" TextWrapping="Wrap" FontSize="11" />
                </StackPanel>
              </ScrollViewer>
            </TabItem>

            <TabItem Header="Collab">
              <ScrollViewer>
                <StackPanel Spacing="10" Margin="4">
                  <TextBlock Text="VR OpenXR" FontWeight="SemiBold" Foreground="#E8EEF7" />
                  <TextBlock Text="Session native Silk.NET lorsque le loader/runtime est présent. Lab : SYNAPSE_VR_SIMULATE=1."
                             Foreground="#8B9BB4" TextWrapping="Wrap" FontSize="11" />
                  <TextBlock Text="{Binding VrStatusText}" Foreground="#45E0B8" TextWrapping="Wrap" FontSize="11" />
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="Activer VR" Command="{Binding EnableVrCommand}" />
                    <Button Content="Arrêter" Command="{Binding DisableVrCommand}" />
                  </StackPanel>

                  <Separator Margin="0,8" />

                  <TextBlock Text="P2P WAN" FontWeight="SemiBold" Foreground="#E8EEF7" />
                  <TextBlock Text="STUN + hole-punch + AES-GCM. Partagez le code et le port rendez-vous UDP avec le pair."
                             Foreground="#8B9BB4" TextWrapping="Wrap" FontSize="11" />
                  <TextBox Text="{Binding WanSessionCode}" Watermark="Code de session…" />
                  <Grid ColumnDefinitions="*,*">
                    <StackPanel Grid.Column="0" Margin="0,0,4,0">
                      <TextBlock Text="Port TCP" Foreground="#8B9BB4" FontSize="11" />
                      <NumericUpDown Value="{Binding WanPort}" Minimum="1" Maximum="65535" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="4,0,0,0">
                      <TextBlock Text="Rendez-vous UDP" Foreground="#8B9BB4" FontSize="11" />
                      <NumericUpDown Value="{Binding WanRendezvousPort}" Minimum="0" Maximum="65535" />
                    </StackPanel>
                  </Grid>
                  <TextBlock Text="{Binding WanStatusText}" Foreground="#45E0B8" TextWrapping="Wrap" FontSize="11" />
                  <StackPanel Orientation="Horizontal" Spacing="6">
                    <Button Content="Héberger" Command="{Binding StartWanHostCommand}" />
                    <Button Content="Rejoindre" Command="{Binding JoinWanCommand}" />
                    <Button Content="Quitter" Command="{Binding StopWanCommand}" />
                  </StackPanel>

                  <Separator Margin="0,8" />

                  <TextBlock Text="Web Studio WASM" FontWeight="SemiBold" Foreground="#E8EEF7" />
                  <TextBlock Text="Publie le projet Blazor + scene.synapse.json pour édition navigateur / WebGPU."
                             Foreground="#8B9BB4" TextWrapping="Wrap" FontSize="11" />
                  <TextBlock Text="{Binding WebStatusText}" Foreground="#45E0B8" TextWrapping="Wrap" FontSize="11" />
                  <Button Content="Exporter Web Studio…" Command="{Binding ExportWebStudioCommand}" HorizontalAlignment="Stretch" />
                  <TextBlock Text="{Binding CollaborationStatus}" Foreground="#C5D0E0" TextWrapping="Wrap" FontSize="11" />
                </StackPanel>
              </ScrollViewer>
            </TabItem>
          </TabControl>
        </DockPanel>
      </Border>

      <!-- Center viewport -->
      <Border Grid.Column="1" Background="#0A0D12">
        <Grid RowDefinitions="Auto,*">
          <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="12,8,12,0">
            <CheckBox Content="Grille" IsChecked="{Binding ShowViewportGrid}" />
            <CheckBox Content="Gizmos" IsChecked="{Binding ShowViewportGizmos}" />
            <Button Content="Sélection" Command="{Binding SetViewportToolSelectCommand}" Padding="8,4" />
            <Button Content="Déplacer" Command="{Binding SetViewportToolTranslateCommand}" Padding="8,4" />
            <Button Content="Rotation" Command="{Binding SetViewportToolRotateCommand}" Padding="8,4" />
            <TextBlock Text="{Binding GiStatus}" Foreground="#45E0B8" VerticalAlignment="Center" FontSize="11" />
          </StackPanel>
          <Grid Grid.Row="1">
            <views:VulkanViewportControl x:Name="Viewport" />
            <Border VerticalAlignment="Top" HorizontalAlignment="Left" Margin="12" Padding="10,6"
                    Background="#990E1218" CornerRadius="4">
              <TextBlock Text="{Binding ViewportHint}" Foreground="#C5D0E0" FontSize="12" />
            </Border>
          </Grid>
        </Grid>
      </Border>

      <!-- Right: inspector + assistant -->
      <Border Grid.Column="2" Background="#12171F" BorderBrush="#1E2633" BorderThickness="1,0,0,0" Padding="8">
        <TabControl>
          <TabItem Header="Inspecteur">
            <ScrollViewer>
              <StackPanel Spacing="10" Margin="4">
                <TextBlock Text="Propriétés" FontWeight="SemiBold" Foreground="#E8EEF7" />
                <TextBlock Text="Sélectionnez une entité dans l'onglet Scène pour éditer ses propriétés."
                           Foreground="#8B9BB4" TextWrapping="Wrap" FontSize="11"
                           IsVisible="{Binding !HasSelectedEntity}" />
                <StackPanel Spacing="8" IsVisible="{Binding HasSelectedEntity}">
                  <TextBlock Text="Nom" Foreground="#8B9BB4" FontSize="11" />
                  <TextBox Text="{Binding EntityName}" />
                  <TextBlock Text="Position (X Y Z)" Foreground="#8B9BB4" FontSize="11" />
                  <Grid ColumnDefinitions="*,*,*">
                    <NumericUpDown Grid.Column="0" Value="{Binding EntityPosX}" Increment="0.1" Margin="0,0,4,0" />
                    <NumericUpDown Grid.Column="1" Value="{Binding EntityPosY}" Increment="0.1" Margin="4,0" />
                    <NumericUpDown Grid.Column="2" Value="{Binding EntityPosZ}" Increment="0.1" Margin="4,0,0,0" />
                  </Grid>
                  <TextBlock Text="{Binding InspectorMeta}" Foreground="#8B9BB4" TextWrapping="Wrap" FontSize="11" />
                  <TextBlock Text="Mesh (chemin)" Foreground="#8B9BB4" FontSize="11" />
                  <TextBox Text="{Binding EntityMeshPath}" Watermark="chemin glTF / OBJ…" />
                  <Grid ColumnDefinitions="*,*">
                    <Button Grid.Column="0" Content="Parcourir mesh…" Command="{Binding BrowseMeshCommand}" Margin="0,0,4,0" />
                    <Button Grid.Column="1" Content="Véhicule" Command="{Binding MarkAsVehicleCommand}" Margin="4,0,0,0" />
                  </Grid>
                  <CheckBox Content="Bake G-DNN SDF" IsChecked="{Binding EntityBakeNeuralSdf}" />
                  <CheckBox Content="Est un véhicule" IsChecked="{Binding EntityIsVehicle}" />
                  <TextBlock Text="Joints" FontWeight="SemiBold" Foreground="#E8EEF7" Margin="0,8,0,0" />
                  <Grid ColumnDefinitions="*,*">
                    <Button Grid.Column="0" Content="Charnière monde" Command="{Binding AddHingeToWorldCommand}" Margin="0,0,4,0" />
                    <Button Grid.Column="1" Content="Partner" Command="{Binding RememberJointPartnerCommand}" Margin="4,0,0,0" />
                  </Grid>
                  <Button Content="Distance → partner" Command="{Binding AddDistanceToPartnerCommand}" HorizontalAlignment="Stretch" />
                  <Button Content="Resync physique" Command="{Binding ResyncPhysicsCommand}" HorizontalAlignment="Stretch" />
                  <TextBlock Text="{Binding PhysicsToolsStatus}" Foreground="#45E0B8" TextWrapping="Wrap" FontSize="11" />
                  <Button Content="Appliquer les modifications" Command="{Binding ApplyInspectorCommand}" HorizontalAlignment="Stretch" />
                </StackPanel>
              </StackPanel>
            </ScrollViewer>
          </TabItem>

          <TabItem Header="Live">
            <ScrollViewer>
              <StackPanel Spacing="10" Margin="4">
                <TextBlock Text="Inspecteur live" FontWeight="SemiBold" Foreground="#E8EEF7" />
                <TextBlock Text="Flux temps réel : évolution NEAT-G, compilations et hot-reload de lois."
                           Foreground="#8B9BB4" TextWrapping="Wrap" FontSize="11" />
                <CheckBox Content="Activer le mode inspecteur"
                          IsChecked="{Binding IsInspectorModeEnabled}" />
                <TextBlock Text="{Binding InspectorFeedStatus}" Foreground="#45E0B8" FontSize="11" TextWrapping="Wrap" />
                <Button Content="Vider le flux" Command="{Binding ClearInspectorFeedCommand}" HorizontalAlignment="Stretch" />
                <ListBox ItemsSource="{Binding InspectorFeed}" Height="420" Background="#0E1218">
                  <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="contracts:LiveInspectorEntry">
                      <Border BorderBrush="#1E2633" BorderThickness="0,0,0,1" Padding="0,0,0,8" Margin="0,0,0,4">
                        <StackPanel Spacing="2">
                          <Grid ColumnDefinitions="Auto,*,Auto">
                            <TextBlock Grid.Column="0" Text="{Binding DisplayTime}" Foreground="#6B7A94" FontSize="10" Margin="0,0,8,0" />
                            <TextBlock Grid.Column="1" Text="{Binding Category}" Foreground="#45E0B8" FontSize="10" />
                            <TextBlock Grid.Column="2" Text="{Binding Title}" Foreground="#E8EEF7" FontSize="11" HorizontalAlignment="Right" />
                          </Grid>
                          <TextBlock Text="{Binding Detail}" Foreground="#8B9BB4" TextWrapping="Wrap" FontSize="11" />
                        </StackPanel>
                      </Border>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </StackPanel>
            </ScrollViewer>
          </TabItem>

          <TabItem Header="Assistant">
            <ScrollViewer>
              <StackPanel Spacing="10" Margin="4">
                <TextBlock Text="Console LLM" FontWeight="SemiBold" Foreground="#E8EEF7" />
                <TextBlock Text="{Binding LlmStatusText}" Foreground="#45E0B8" FontSize="11" TextWrapping="Wrap" />
                <ListBox ItemsSource="{Binding ChatMessages}" Height="200" Background="#0E1218">
                  <ListBox.ItemTemplate>
                    <DataTemplate>
                      <StackPanel Margin="0,0,0,8">
                        <TextBlock Text="{Binding Role}" Foreground="#45E0B8" FontSize="11" />
                        <TextBlock Text="{Binding Content}" Foreground="#E8EEF7" TextWrapping="Wrap" />
                      </StackPanel>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
                <TextBox Text="{Binding ChatInput}" Watermark="Décrivez l'éclairage ou une forme SDF…"
                         AcceptsReturn="True" Height="64" />
                <Grid ColumnDefinitions="*,*,*">
                  <Button Grid.Column="0" Content="Modèle éclairage" Command="{Binding InsertLightingPromptCommand}" Margin="0,0,4,0" />
                  <Button Grid.Column="1" Content="Modèle SDF" Command="{Binding InsertSdfPromptCommand}" Margin="4,0" />
                  <Button Grid.Column="2" Content="Modèle BT" Command="{Binding InsertBehaviorPromptCommand}" Margin="4,0,0,0" />
                </Grid>
                <Button Content="Envoyer" Command="{Binding SendChatCommand}" HorizontalAlignment="Stretch" />
                <Button Content="Appliquer la dernière réponse" Command="{Binding ApplyLastLlmReplyCommand}" HorizontalAlignment="Stretch" />
                <TextBlock Text="{Binding LlmApplyStatus}" Foreground="#8B9BB4" TextWrapping="Wrap" FontSize="11" />
              </StackPanel>
            </ScrollViewer>
          </TabItem>

          <TabItem Header="Performance">
            <ScrollViewer>
              <StackPanel Spacing="10" Margin="4">
                <TextBlock Text="{Binding PerformanceReport}" Foreground="#8B9BB4" TextWrapping="Wrap" />
                <TextBlock Text="{Binding SimulationStatus}" Foreground="#C5D0E0" TextWrapping="Wrap" />
                <TextBlock Text="À propos de Synapse OMNIA" FontWeight="SemiBold" Foreground="#45E0B8"
                           IsVisible="{Binding ShowAboutText}" />
                <TextBlock Text="{Binding AboutText}" Foreground="#8B9BB4" TextWrapping="Wrap" FontSize="11"
                           IsVisible="{Binding ShowAboutText}" />
              </StackPanel>
            </ScrollViewer>
          </TabItem>
        </TabControl>
      </Border>
    </Grid>
  </DockPanel>
</Window>
