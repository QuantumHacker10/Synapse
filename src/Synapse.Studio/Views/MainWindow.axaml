<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:GDNN.Studio.ViewModels"
        xmlns:views="using:GDNN.Studio.Views"
        x:Class="GDNN.Studio.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="G-DNN Studio — SYNAPSE OMNIA"
        Width="1440" Height="900"
        MinWidth="1100" MinHeight="700"
        Background="#0E1218">

  <DockPanel>
    <!-- Menu -->
    <Menu DockPanel.Dock="Top" Background="#161B22">
      <MenuItem Header="_File">
        <MenuItem Header="New Project" Command="{Binding NewProjectCommand}" />
        <MenuItem Header="Open…" Command="{Binding OpenProjectCommand}" />
        <MenuItem Header="Save" Command="{Binding SaveProjectCommand}" />
        <Separator />
        <MenuItem Header="Exit" Command="{Binding ExitCommand}" />
      </MenuItem>
      <MenuItem Header="_Simulation">
        <MenuItem Header="Play / Pause" Command="{Binding TogglePlayCommand}" />
        <MenuItem Header="Spawn Agent" Command="{Binding SpawnAgentCommand}" />
      </MenuItem>
      <MenuItem Header="_Tools">
        <MenuItem Header="New Blueprint" Command="{Binding NewBlueprintCommand}" />
        <MenuItem Header="Compile Blueprint" Command="{Binding CompileBlueprintCommand}" />
        <MenuItem Header="Import Megascans…" Command="{Binding ImportMegascansCommand}" />
      </MenuItem>
      <MenuItem Header="_Help">
        <MenuItem Header="About Synapse" Command="{Binding AboutCommand}" />
      </MenuItem>
    </Menu>

    <!-- Status bar -->
    <Border DockPanel.Dock="Bottom" Background="#161B22" Padding="12,6">
      <Grid ColumnDefinitions="*,*,*,*,*">
        <TextBlock Grid.Column="0" Foreground="#8B9BB4" Text="{Binding StatusFps}" />
        <TextBlock Grid.Column="1" Foreground="#8B9BB4" Text="{Binding StatusPhysics}" />
        <TextBlock Grid.Column="2" Foreground="#8B9BB4" Text="{Binding StatusSimulation}" />
        <TextBlock Grid.Column="3" Foreground="#8B9BB4" Text="{Binding StatusQuality}" />
        <TextBlock Grid.Column="4" Foreground="#45E0B8" Text="{Binding StatusLaw}" HorizontalAlignment="Right" />
      </Grid>
    </Border>

    <Grid ColumnDefinitions="280,*,320">
      <!-- Left: Scene + Laws -->
      <Border Grid.Column="0" Background="#12171F" BorderBrush="#1E2633" BorderThickness="0,0,1,0" Padding="12">
        <ScrollViewer>
          <StackPanel Spacing="16">
            <TextBlock Text="Scene" FontSize="16" FontWeight="SemiBold" Foreground="#E8EEF7" />
            <ListBox ItemsSource="{Binding Entities}" SelectedItem="{Binding SelectedEntity}"
                     Background="Transparent" MaxHeight="220">
              <ListBox.ItemTemplate>
                <DataTemplate>
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="{Binding Type}" Foreground="#45E0B8" Width="70" />
                    <TextBlock Text="{Binding Name}" Foreground="#E8EEF7" />
                  </StackPanel>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Button Content="Add Entity" Command="{Binding AddEntityCommand}" />
              <Button Content="Delete" Command="{Binding DeleteEntityCommand}" />
            </StackPanel>

            <TextBlock Text="Living Laws" FontSize="16" FontWeight="SemiBold" Foreground="#E8EEF7" Margin="0,8,0,0" />
            <ComboBox ItemsSource="{Binding LawIds}" SelectedItem="{Binding SelectedLawId}" Width="240" />
            <TextBox Text="{Binding LawExpression}" AcceptsReturn="True" Height="100"
                     Watermark="Law expression…" TextWrapping="Wrap" />
            <Button Content="Compile &amp; Hot-Reload" Command="{Binding CompileLawCommand}" HorizontalAlignment="Stretch" />
            <TextBlock Text="{Binding LawStatus}" Foreground="#8B9BB4" TextWrapping="Wrap" />

            <TextBlock Text="Evolution (NEAT-G)" FontSize="16" FontWeight="SemiBold" Foreground="#E8EEF7" Margin="0,8,0,0" />
            <TextBlock Text="{Binding EvolutionStatus}" Foreground="#8B9BB4" />
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Button Content="Evolve" Command="{Binding StartEvolutionCommand}" />
              <Button Content="Cancel" Command="{Binding CancelEvolutionCommand}" />
            </StackPanel>

            <TextBlock Text="Blueprint" FontSize="16" FontWeight="SemiBold" Foreground="#E8EEF7" Margin="0,8,0,0" />
            <ListBox ItemsSource="{Binding BlueprintNodes}" Height="100" Background="#0E1218" />
            <TextBlock Text="{Binding BlueprintStatus}" Foreground="#8B9BB4" TextWrapping="Wrap" />
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Button Content="Add" Command="{Binding AddBlueprintNodeCommand}" />
              <Button Content="Compile" Command="{Binding CompileBlueprintCommand}" />
              <Button Content="Save" Command="{Binding SaveBlueprintCommand}" />
            </StackPanel>

            <TextBlock Text="Sculpt" FontSize="16" FontWeight="SemiBold" Foreground="#E8EEF7" Margin="0,8,0,0" />
            <TextBlock Text="Radius" Foreground="#8B9BB4" FontSize="11" />
            <Slider Minimum="0.05" Maximum="3" Value="{Binding SculptRadius}" />
            <TextBlock Text="Strength" Foreground="#8B9BB4" FontSize="11" />
            <Slider Minimum="0.01" Maximum="1" Value="{Binding SculptStrength}" />
            <CheckBox Content="Invert" IsChecked="{Binding SculptInvert}" Foreground="#E8EEF7" />
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Button Content="Stroke @ selection" Command="{Binding ApplySculptStrokeCommand}" />
              <Button Content="Clear" Command="{Binding ClearSculptCommand}" />
            </StackPanel>
            <TextBlock Text="{Binding SculptStatus}" Foreground="#8B9BB4" TextWrapping="Wrap" />

            <TextBlock Text="Megascans" FontSize="16" FontWeight="SemiBold" Foreground="#E8EEF7" Margin="0,8,0,0" />
            <TextBox Text="{Binding MegascansPath}" Watermark="Asset folder path…" />
            <Button Content="Import asset" Command="{Binding ImportMegascansCommand}" HorizontalAlignment="Stretch" />
            <TextBlock Text="{Binding MegascansStatus}" Foreground="#8B9BB4" TextWrapping="Wrap" />
          </StackPanel>
        </ScrollViewer>
      </Border>

      <!-- Center: Viewport -->
      <Border Grid.Column="1" Background="#0A0D12">
        <Grid>
          <views:VulkanViewportControl x:Name="Viewport" />
          <Border VerticalAlignment="Top" HorizontalAlignment="Left" Margin="12" Padding="10,6"
                  Background="#990E1218" CornerRadius="4">
            <TextBlock Text="{Binding ViewportHint}" Foreground="#C5D0E0" FontSize="12" />
          </Border>
        </Grid>
      </Border>

      <!-- Right: LLM + Performance + Inspector -->
      <Border Grid.Column="2" Background="#12171F" BorderBrush="#1E2633" BorderThickness="1,0,0,0" Padding="12">
        <ScrollViewer>
          <StackPanel Spacing="16">
            <TextBlock Text="Inspector" FontSize="16" FontWeight="SemiBold" Foreground="#E8EEF7" />
            <TextBlock Text="{Binding InspectorText}" Foreground="#8B9BB4" TextWrapping="Wrap" />

            <TextBlock Text="LLM Console" FontSize="16" FontWeight="SemiBold" Foreground="#E8EEF7" Margin="0,8,0,0" />
            <ListBox ItemsSource="{Binding ChatMessages}" Height="180" Background="#0E1218">
              <ListBox.ItemTemplate>
                <DataTemplate>
                  <StackPanel Margin="0,0,0,8">
                    <TextBlock Text="{Binding Role}" Foreground="#45E0B8" FontSize="11" />
                    <TextBlock Text="{Binding Content}" Foreground="#E8EEF7" TextWrapping="Wrap" />
                  </StackPanel>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
            <TextBox Text="{Binding ChatInput}" Watermark="Ask Synapse… (lighting / SDF JSON)" AcceptsReturn="True" Height="60" />
            <Grid ColumnDefinitions="*,*" Margin="0,0,0,0">
              <Button Grid.Column="0" Content="Lighting prompt" Command="{Binding InsertLightingPromptCommand}" Margin="0,0,4,0" HorizontalAlignment="Stretch" />
              <Button Grid.Column="1" Content="SDF prompt" Command="{Binding InsertSdfPromptCommand}" Margin="4,0,0,0" HorizontalAlignment="Stretch" />
            </Grid>
            <Button Content="Send" Command="{Binding SendChatCommand}" HorizontalAlignment="Stretch" />
            <Button Content="Apply last reply → scene" Command="{Binding ApplyLastLlmReplyCommand}" HorizontalAlignment="Stretch" />
            <TextBlock Text="{Binding LlmApplyStatus}" Foreground="#45E0B8" TextWrapping="Wrap" FontSize="11" />

            <TextBlock Text="Performance" FontSize="16" FontWeight="SemiBold" Foreground="#E8EEF7" Margin="0,8,0,0" />
            <TextBlock Text="{Binding PerformanceReport}" Foreground="#8B9BB4" TextWrapping="Wrap" />

            <TextBlock Text="Simulation" FontSize="16" FontWeight="SemiBold" Foreground="#E8EEF7" Margin="0,8,0,0" />
            <TextBlock Text="{Binding SimulationStatus}" Foreground="#8B9BB4" TextWrapping="Wrap" />
            <Button Content="{Binding PlayPauseLabel}" Command="{Binding TogglePlayCommand}" HorizontalAlignment="Stretch" />
          </StackPanel>
        </ScrollViewer>
      </Border>
    </Grid>
  </DockPanel>
</Window>
